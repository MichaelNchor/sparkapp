---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

/*
 * Luvmood landing — Bumble's "make the first move" concept rendered in the
 * app's own wine-purple dark theme (see spark/utils/theme.tsx DARK palette).
 * Photo-led, soft-rounded, confident. The signature element is a rotating
 * profile-card hero deck. Every face is a real, verified Unsplash portrait
 * (IDs re-checked HTTP 200 + caption-matched) — no gradient placeholders,
 * no invented stats or testimonials (honest-copy rule).
 *
 * Self-contained: all styling is scoped here (incl. dark-theming the shared
 * Nav/Footer via :global on THIS page only), so the legal routes keep
 * global.css untouched.
 */
const u = (id: string, w = 640, h = 0) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&q=80&w=${w}${h ? `&h=${h}` : ''}`;

const maya   = '1525134479668-1bee5c7c6845';
const amara  = '1524550158212-33f2ff985344';
const daniel = '1600603406200-5b2a104684ac';
const sofia  = '1494790108377-be9c29b29330';
const leila  = '1567516364473-233c4b6fcfbe';
const nadia  = '1544005313-94ddf0286df2';
const kofi   = '1463453091185-61582044d556';

// Hero deck — real verified members the card carousel cycles through.
const deck = [
  { id: maya,   name: 'Maya',   age: 26, dist: '2 km away', alt: 'Maya, 26, smiling in a field at golden hour' },
  { id: daniel, name: 'Daniel', age: 28, dist: '1 km away', alt: 'Daniel, 28, in a blue shirt' },
  { id: sofia,  name: 'Sofia',  age: 27, dist: '3 km away', alt: 'Sofia, 27, laughing' },
  { id: kofi,   name: 'Kofi',   age: 29, dist: '4 km away', alt: 'Kofi, 29, street portrait' },
  { id: leila,  name: 'Leila',  age: 25, dist: '2 km away', alt: 'Leila, 25, soft smile' },
];
---

<Layout title="Luvmood — Make the first move">
  <div class="scroll-progress" aria-hidden="true"></div>
  <Nav />

  <main class="lp">
    <!-- ============================================================ HERO -->
    <section class="hero" id="top">
      <span class="bloom bloom--pink" aria-hidden="true"></span>
      <span class="bloom bloom--violet" aria-hidden="true"></span>
      <div class="hero__grid shell">
        <div class="hero__copy">
          <span class="pill reveal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
            Photo-verified dating
          </span>

          <h1 class="hero__title reveal-lines">
            <span class="line"><span style="--d:80ms">Make the</span></span>
            <span class="line"><span style="--d:200ms"><span class="grad">first move.</span></span></span>
          </h1>

          <p class="hero__sub reveal" style="--d:340ms">
            No match required. On Luvmood you can say hi to anyone first, every profile is photo-verified by a selfie match, so the people you meet really look like their pictures.
          </p>

          <div class="hero__ctas reveal" style="--d:440ms">
            <a href="#get" class="btn btn--primary" data-magnetic>Get the app</a>
            <a href="#how" class="btn btn--ghost">
              How it works
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="hero__trust reveal" style="--d:540ms">
            <span class="facepile" aria-hidden="true">
              <img src={u(amara, 96, 96)} alt="" loading="eager" />
              <img src={u(daniel, 96, 96)} alt="" loading="eager" />
              <img src={u(sofia, 96, 96)} alt="" loading="eager" />
            </span>
            <span><b>Verified profiles.</b> Free on iOS &amp; Android.</span>
          </div>
        </div>

        <!-- Rotating profile-card deck (Bumble's signature hero move) -->
        <div class="hero__stage reveal" style="--d:260ms">
          <div class="deck" aria-label="A few verified Luvmood members">
            {deck.map((p, i) => (
              <article class="pcard" data-pos={i}>
                <img src={u(p.id, 640, 820)} alt={p.alt} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
                <span class="pcard__scrim" aria-hidden="true"></span>
                <span class="pcard__badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
                  Verified
                </span>
                <div class="pcard__meta">
                  <div class="pcard__line">
                    <h3>{p.name} <span>{p.age}</span></h3>
                    <span class="pcard__dist">
                      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                      {p.dist}
                    </span>
                  </div>
                  <span class="pcard__hi">Say hi
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
                  </span>
                </div>
              </article>
            ))}
          </div>

          <div class="chip chip--a" data-float>
            <img src={u(amara, 72, 72)} alt="" loading="lazy" />
            <div><strong>Amara liked you</strong><em>Verified · 4 km</em></div>
          </div>
          <div class="chip chip--b" data-float="b">
            <span class="chip__ic">💬</span>
            <div><strong>Daniel said hi</strong><em>“Coffee this week?”</em></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ TRUST -->
    <section class="trust shell">
      <div class="trust__item reveal">
        <span class="trust__ic ic--pink"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg></span>
        <div><strong>Photo verified</strong><span>Selfie matched to your profile photo</span></div>
      </div>
      <div class="trust__item reveal" style="--d:90ms">
        <span class="trust__ic ic--violet"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M15 9 9 15M9 9l6 6"/></svg></span>
        <div><strong>Block &amp; report fast</strong><span>Two taps, and we act on it</span></div>
      </div>
      <div class="trust__item reveal" style="--d:180ms">
        <span class="trust__ic ic--coral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
        <div><strong>Real people near you</strong><span>Nobody you can't actually meet</span></div>
      </div>
    </section>

    <!-- ====================================================== MARKER CARDS -->
    <section class="section" id="how">
      <div class="shell">
        <div class="head reveal">
          <span class="eyebrow">Everything you need</span>
          <h2 class="h2">A dating app that actually wants you to talk.</h2>
        </div>
        <div class="markers">
          <article class="marker reveal" style="--d:0ms; --m:var(--pink)">
            <span class="marker__ic">📸</span>
            <h3>Photo-verified</h3>
            <p>Every profile clears a selfie-match check. The Verified badge means it's real.</p>
          </article>
          <article class="marker reveal" style="--d:70ms; --m:var(--violet)">
            <span class="marker__ic">💬</span>
            <h3>Say hi first</h3>
            <p>Send a chat request without a match. It lands at the top of their inbox.</p>
          </article>
          <article class="marker reveal" style="--d:140ms; --m:var(--blue)">
            <span class="marker__ic">📞</span>
            <h3>Voice &amp; video</h3>
            <p>Call inside the app once you've connected. Your number stays private.</p>
          </article>
          <article class="marker reveal" style="--d:210ms; --m:var(--gold)">
            <span class="marker__ic">⚡</span>
            <h3>Vibes</h3>
            <p>Drop a one-line vibe. People around you who match it reach out.</p>
          </article>
          <article class="marker reveal" style="--d:280ms; --m:var(--green)">
            <span class="marker__ic">🗺️</span>
            <h3>Nearby</h3>
            <p>See where Sparkers are, by area. Approximate, never your exact spot.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============================================ FEATURE — first move -->
    <section class="section section--band" id="features">
      <span class="bloom bloom--violet bloom--soft" aria-hidden="true"></span>
      <div class="shell feature">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--violet">The first move</span>
          <h2 class="h2">Like them? Say it. Today, not someday.</h2>
          <p class="lead">Most apps make you both swipe right, then hope someone breaks the silence. On Luvmood you spend a few coins to send a real opening line, it lands above the noise, they accept, you're talking.</p>
          <ul class="ticks">
            <li>No mutual-swipe required to reach out.</li>
            <li>They see your name, photo, and message, then decide.</li>
            <li>The coin cost keeps inboxes clean. No spam.</li>
          </ul>
        </div>
        <div class="feature__visual reveal reveal--right">
          <div class="reqcard">
            <div class="reqcard__top">
              <span>Requests</span>
              <span class="reqcard__coin">● 12</span>
            </div>
            <div class="reqcard__body">
              <img src={u(daniel, 120, 120)} alt="" loading="lazy" />
              <div>
                <strong>Daniel, 28</strong>
                <em>Verified · 1 km away</em>
              </div>
            </div>
            <p class="reqcard__msg">ok so the bouldering thing wasn't a line, you actually go?</p>
            <div class="reqcard__actions">
              <span class="reqcard__btn reqcard__btn--yes">Accept</span>
              <span class="reqcard__btn reqcard__btn--no">Maybe later</span>
            </div>
            <span class="reqcard__hint">Accepted in 6 minutes.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ FEATURE — calls (rev) -->
    <section class="section">
      <div class="shell feature feature--reverse">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--blue">Voice &amp; video</span>
          <h2 class="h2">Hear the laugh before you meet.</h2>
          <p class="lead">Calls live inside Luvmood, only after you've matched or accepted a request. Take the edge off the first meet, and never hand your number to a stranger.</p>
          <ul class="ticks">
            <li>Calls only after you've connected.</li>
            <li>Your number stays private. Always.</li>
            <li>End the call any time, no hard feelings.</li>
          </ul>
        </div>
        <div class="feature__visual reveal reveal--left">
          <figure class="photo photo--tall">
            <img src={u(sofia, 760, 950)} alt="Sofia, a verified member, mid-call" loading="lazy" />
            <span class="photo__badge" aria-hidden="true"></span>
            <span class="callbar" aria-hidden="true">
              <span></span><span></span><span class="callbar__end"></span>
            </span>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============================================ FEATURE — vibes -->
    <section class="section section--band">
      <div class="shell feature">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--pink">Vibes</span>
          <h2 class="h2">Drop a vibe. See who's around.</h2>
          <p class="lead">Post a one-line vibe, what you're doing, what you're up for, where you are. People nearby who match it send a request. The easiest way to start something without the whole swipe ritual.</p>
          <ul class="ticks">
            <li>Vibes expire after 24 hours. No old posts haunting you.</li>
            <li>Only verified people can post or reply.</li>
            <li>Filtered to your age range and people you'd actually meet.</li>
          </ul>
        </div>
        <div class="feature__visual reveal reveal--right">
          <div class="vibes">
            <div class="vibe">
              <img src={u(leila, 96, 96)} alt="" loading="lazy" />
              <div><div class="vibe__h"><strong>Leila, 25</strong><em>2 km · 1h</em></div><p>Free Sunday afternoon, museum or beach?</p></div>
            </div>
            <div class="vibe">
              <img src={u(kofi, 96, 96)} alt="" loading="lazy" />
              <div><div class="vibe__h"><strong>Kofi, 29</strong><em>4 km · 3h</em></div><p>Coffee at Vida e Caffe in an hour, anyone?</p></div>
            </div>
            <div class="vibe">
              <img src={u(nadia, 96, 96)} alt="" loading="lazy" />
              <div><div class="vibe__h"><strong>Nadia, 26</strong><em>1 km · 5h</em></div><p>First time at the gym today, no judgement plz</p></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====================================================== VERIFIED -->
    <section class="section" id="verified">
      <div class="shell">
        <div class="head reveal">
          <span class="eyebrow">Real people only</span>
          <h2 class="h2">No bots. No catfish. No “wait, is this real?”</h2>
          <p class="lead lead--center">Verification isn't a blue tick you buy. On Luvmood it's the front door, there's no other way in.</p>
        </div>

        <div class="facewall reveal reveal--scale" aria-label="A few verified Luvmood members">
          <figure><img src={u(amara, 440, 580)} alt="Amara, a verified member with auburn hair" loading="lazy" /></figure>
          <figure><img src={u(daniel, 440, 580)} alt="Daniel, a verified member in a blue shirt" loading="lazy" /></figure>
          <figure><img src={u(leila, 440, 580)} alt="Leila, a verified member smiling" loading="lazy" /></figure>
          <figure><img src={u(nadia, 440, 580)} alt="Nadia, a verified member in a striped shirt" loading="lazy" /></figure>
          <figure class="facewall__wide"><img src={u(sofia, 880, 560)} alt="Sofia, a verified member laughing" loading="lazy" /></figure>
        </div>

        <div class="safety">
          <article class="safety__card reveal">
            <span class="safety__ic ic--pink"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg></span>
            <h3>Face-match on the way in</h3>
            <p>A fresh selfie is matched to your profile photo. Change your photo later and the check re-runs.</p>
          </article>
          <article class="safety__card reveal" style="--d:90ms">
            <span class="safety__ic ic--violet"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <h3>You set the limits</h3>
            <p>Age range, distance, and visibility are in your hands. Pause your profile when you need a break.</p>
          </article>
          <article class="safety__card reveal" style="--d:180ms">
            <span class="safety__ic ic--green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <h3>Reports reach a human</h3>
            <p>Every report gets looked at. Repeat offenders get banned across all their accounts. Your data is never sold.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============================================================ CTA -->
    <section id="get">
      <div class="cta shell reveal">
        <span class="cta__bloom" aria-hidden="true"></span>
        <div class="cta__inner">
          <h2 class="cta__title">Go meet someone real.</h2>
          <p class="cta__sub">Free to download. Get photo-verified in a minute, then make the first move.</p>
          <div class="stores">
            <!-- TODO: real App Store / Play Store URLs once published. -->
            <a class="store" href="#" aria-label="Download on the App Store">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 12.6c0-3.1 2.5-4.6 2.7-4.7-1.5-2.2-3.8-2.5-4.6-2.5-2-.2-3.8 1.2-4.8 1.2-1 0-2.5-1.1-4.2-1.1-2.2 0-4.2 1.3-5.3 3.2-2.3 4-.6 9.9 1.6 13.2 1.1 1.6 2.4 3.4 4.1 3.3 1.7-.1 2.3-1.1 4.3-1.1 2 0 2.6 1.1 4.4 1 1.8 0 2.9-1.6 4-3.2.5-.8.7-1.2 1.1-2.1-3-.9-3.3-4.7-3.3-5.2zM14.4 4c.9-1.1 1.5-2.6 1.4-4.1-1.3.1-2.9.9-3.8 2-.8.9-1.5 2.5-1.3 3.9 1.4.1 2.9-.7 3.7-1.8z"/></svg>
              <span><em>Download on the</em><strong>App Store</strong></span>
            </a>
            <a class="store" href="#" aria-label="Get it on Google Play">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 2.5v19l10-9.5L3 2.5z" fill="#fd297b"/><path d="M13 12 3 21.5l10.5-5.5L13 12z" fill="#14C25E"/><path d="M13 12l.5-4-10.5-5.5L13 12z" fill="#1E9BFF"/><path d="M21.5 11.1 17.5 8.8 13.5 12l4 3.2 4-2.3c1.5-.8 1.5-2.6 0-3.4z" fill="#F59E0B"/></svg>
              <span><em>Get it on</em><strong>Google Play</strong></span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Dark-theme the shared chrome (Nav + Footer + page) — index page only. */
  html { color-scheme: dark; }
  body { background: #0E0612; }

  .nav-wrap.is-stuck {
    background: rgba(14, 6, 18, 0.72) !important;
    box-shadow: 0 1px 0 rgba(255,255,255,0.06), 0 18px 40px -28px rgba(0,0,0,0.8) !important;
  }
  .nav .brand__name { color: #fff; }
  .nav__links a { color: #C4B5CC; }
  .nav__links a:hover { color: #fff; background: rgba(253,41,123,0.14); }
  .nav__cta { background: #fd297b; color: #fff; box-shadow: 0 14px 30px -12px rgba(253,41,123,0.6); }
  .nav__cta:hover { background: #ff4d8d; }

  .footer { background: #0B040F; border-top: 1px solid rgba(255,255,255,0.07); }
  .footer__tag { color: #C4B5CC; }
  .footer__col h4 { color: #7A6A82; }
  .footer__col a { color: #C4B5CC; }
  .footer__col a:hover { color: #fd297b; }
  .footer__socials a { background: #150A1C; border-color: #2A1A36; color: #C4B5CC; }
  .footer__socials a:hover { background: #fd297b; color: #fff; border-color: #fd297b; }
  .footer__bottom { border-top: 1px solid rgba(255,255,255,0.07); color: #7A6A82; }
  ::selection { background: #fd297b; color: #fff; }
</style>

<style>
  /* ============================ TOKENS (wine-purple dark) ============================ */
  .lp {
    --bg: #0E0612;
    --surface: #150A1C;
    --surface-2: #1C1024;
    --line: rgba(255,255,255,0.08);
    --line-2: rgba(255,255,255,0.05);
    --ink: #FFFFFF;
    --ink-2: #C4B5CC;
    --ink-3: #8B7A94;
    --pink: #fd297b;
    --coral: #ff5864;
    --coral-2: #ff655b;
    --violet: #8B2FE6;
    --blue: #1E9BFF;
    --gold: #F59E0B;
    --green: #14C25E;
    --grad: linear-gradient(102deg, #fd297b 0%, #ff5864 55%, #ff655b 100%);
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    color: var(--ink);
    font-family: 'Hanken Grotesk', system-ui, sans-serif;
    background: var(--bg);
    overflow-x: clip;
  }
  .lp .shell { width: min(1160px, 92vw); margin-inline: auto; }
  .lp h1, .lp h2, .lp h3 { font-family: 'Bricolage Grotesque', 'Hanken Grotesk', sans-serif; letter-spacing: -0.03em; }
  .lp .section { padding: clamp(72px, 10vw, 132px) 0; position: relative; }
  .lp .section--band { background: linear-gradient(180deg, transparent, rgba(139,47,230,0.05) 30%, rgba(253,41,123,0.04) 70%, transparent); }
  .lp .h2 { font-size: clamp(30px, 4.8vw, 52px); line-height: 1.02; font-weight: 700; margin: 14px 0 0; }
  .lp .eyebrow { display: inline-block; font-size: 12.5px; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--pink); }
  .lp .eyebrow--violet { color: #b07bff; }
  .lp .eyebrow--blue { color: #66bcff; }
  .lp .eyebrow--pink { color: var(--pink); }
  .lp .head { max-width: 760px; }
  .lp .lead { font-size: clamp(16px, 1.6vw, 19px); line-height: 1.6; color: var(--ink-2); margin-top: 16px; max-width: 58ch; }
  .lp .lead--center { text-align: center; margin-inline: auto; }
  .lp .head .lead--center { margin-top: 18px; }
  .lp .grad { background: var(--grad); -webkit-background-clip: text; background-clip: text; color: transparent; }

  /* ambient blooms */
  .lp .bloom { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .lp .bloom--pink { width: 620px; height: 620px; top: -220px; right: -140px; background: radial-gradient(circle, rgba(253,41,123,0.5), transparent 68%); }
  .lp .bloom--violet { width: 560px; height: 560px; bottom: -260px; left: -180px; background: radial-gradient(circle, rgba(139,47,230,0.42), transparent 68%); }
  .lp .bloom--soft { opacity: 0.5; }

  /* ============================ BUTTONS ============================ */
  .lp .btn { position: relative; display: inline-flex; align-items: center; gap: 9px; font-weight: 700; font-size: 16px; border-radius: 999px; padding: 15px 28px; text-decoration: none; transition: transform .25s var(--ease), box-shadow .25s var(--ease), background .25s var(--ease); overflow: hidden; }
  .lp .btn svg { width: 18px; height: 18px; }
  .lp .btn--primary { background: var(--grad); color: #fff; box-shadow: 0 18px 40px -14px rgba(253,41,123,0.7); }
  .lp .btn--primary::after { content: ""; position: absolute; inset: 0; background: linear-gradient(110deg, transparent 25%, rgba(255,255,255,0.4) 50%, transparent 75%); transform: translateX(-135%); transition: transform .8s var(--ease); pointer-events: none; }
