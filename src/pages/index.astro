<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // 1. Reveal-on-scroll
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal, .reveal-lines');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  // 2. Rotating profile-card deck
  const deck = document.querySelector<HTMLElement>('.deck');
  if (deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>('.pcard'));
    let order = cards.map((_, i) => i);
    const apply = () => order.forEach((idx, pos) => { cards[idx].dataset.pos = String(pos); });
    apply();
    if (!reduce && cards.length > 1) {
      let timer: ReturnType<typeof setInterval> | null = null;
      const advance = () => {
        const front = cards[order[0]];
        front.classList.add('pcard--exit');
        setTimeout(() => { order.push(order.shift()!); front.classList.remove('pcard--exit'); apply(); }, 480);
      };
      const start = () => { timer = setInterval(advance, 3200); };
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
      start();
      deck.addEventListener('pointerenter', stop);
      deck.addEventListener('pointerleave', start);
    }
  }

  if (!reduce) {
    // 3. Scroll progress + bloom parallax
    const bar = document.querySelector<HTMLElement>('.scroll-progress');
    const blooms = Array.from(document.querySelectorAll<HTMLElement>('.bloom'));
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        if (bar) bar.style.transform = `scaleX(${max > 0 ? Math.min(y / max, 1) : 0})`;
        blooms.forEach((b, i) => { b.style.transform = `translateY(${y * (i % 2 ? 0.06 : -0.05)}px)`; });
        ticking = false;
      });
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // 4. Magnetic primary CTA (fine pointers only)
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((btn) => {
        btn.addEventListener('pointermove', (ev) => {
          const r = btn.getBoundingClientRect();
          const mx = (ev.clientX - r.left - r.width / 2) / r.width;
          const my = (ev.clientY - r.top - r.height / 2) / r.height;
          btn.style.transform = `translate(${mx * 8}px, ${my * 8 - 2}px)`;
        });
        btn.addEventListener('pointerleave', () => { btn.style.transform = ''; });
      });
    }
  }
</script>
