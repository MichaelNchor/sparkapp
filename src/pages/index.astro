---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

/*
 * Real, verified Unsplash portraits used inside the product mockups so
 * the page shows real faces, not gradient placeholders. IDs were checked
 * to resolve (HTTP 200) before being committed.
 */
const u = (id: string, w = 640, h = 0) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&q=80&w=${w}${h ? `&h=${h}` : ''}`;

const maya   = '1525134479668-1bee5c7c6845'; // denim jacket, golden-hour smile
const amara  = '1524550158212-33f2ff985344'; // auburn hair, calm smile
const daniel = '1600603406200-5b2a104684ac'; // blue tee, relaxed
const sofia  = '1494790108377-be9c29b29330'; // laughing, red top
const leila  = '1567516364473-233c4b6fcfbe'; // soft smile, looking down
const nadia  = '1544005313-94ddf0286df2';    // striped shirt, serene
---

<Layout>
  <Nav />

  <main>
    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="hero" id="top">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="hero__inner">
        <div class="hero__copy">
          <span class="kicker reveal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
            Verified-only dating
          </span>

          <h1 class="hero__title reveal" style="--reveal-delay:80ms">
            Find someone worth <br class="hero-br" />staying <span class="em-pink">offline</span> for.
          </h1>

          <p class="hero__sub reveal" style="--reveal-delay:160ms">
            Spark checks every profile against a real photo and ID before
            they can match. Meet people who are actually who they say
            they are, then make a first move that gets read.
          </p>

          <div class="hero__ctas reveal" style="--reveal-delay:240ms">
            <a href="#get" class="btn btn--primary">Get the app</a>
            <a href="#how" class="textlink">
              See how it works
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="hero__trust reveal" style="--reveal-delay:320ms">
            <span class="facepile" aria-hidden="true">
              <img src={u(amara, 80, 80)} alt="" loading="lazy" />
              <img src={u(daniel, 80, 80)} alt="" loading="lazy" />
              <img src={u(sofia, 80, 80)} alt="" loading="lazy" />
            </span>
            <span><b>Real, human-verified profiles.</b> Free to join on iOS &amp; Android.</span>
          </div>
        </div>

        <div class="hero__stage reveal" style="--reveal-delay:200ms">
          <div class="device" data-tilt>
            <div class="device__notch" aria-hidden="true"></div>
            <div class="device__screen">
              <div class="discover">
                <img src={u(maya, 720, 1040)} alt="Maya, 26, smiling in a field at golden hour" loading="eager" />
                <div class="discover__scrim" aria-hidden="true"></div>
                <span class="discover__verified">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
                  Verified
                </span>
                <div class="discover__meta">
                  <h4>Maya, 26</h4>
                  <p>
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                    2 km away
                  </p>
                </div>
                <div class="discover__actions" aria-hidden="true">
                  <span class="discover__btn discover__btn--pass"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></span>
                  <span class="discover__btn discover__btn--like"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-9.5-8.6C.8 9.3 2.5 5.3 6.2 5.3c2.1 0 3.6 1.2 5.8 3.6 2.2-2.4 3.7-3.6 5.8-3.6 3.7 0 5.4 4 3.7 7.1C19 16.5 12 21 12 21Z"/></svg></span>
                </div>
              </div>
            </div>
          </div>

          <div class="floatcard hero__float--match" data-float>
            <img src={u(amara, 80, 80)} alt="" loading="lazy" />
            <div>
              <strong>Amara liked you</strong>
              <em>Verified · 4 km away</em>
            </div>
          </div>

          <div class="floatcard hero__float--hmu" data-float="b">
            <img src={u(daniel, 80, 80)} alt="" loading="lazy" />
            <div>
              <strong>Daniel sent a request</strong>
              <span class="hmu-mini-msg">“Coffee this week? ☕”</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         TRUST STRIP
         ============================================================ -->
    <section class="trust">
      <div class="trust__inner">
        <div class="trust__item reveal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
          <div><strong>Photo + ID verified</strong><span>Reviewed by a real person</span></div>
        </div>
        <div class="trust__item reveal" style="--reveal-delay:100ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M15 9 9 15M9 9l6 6"/></svg>
          <div><strong>Block &amp; report fast</strong><span>Two taps, and we act on it</span></div>
        </div>
        <div class="trust__item reveal" style="--reveal-delay:200ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
          <div><strong>Real people near you</strong><span>Nobody you can't actually meet</span></div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS
         ============================================================ -->
    <section class="section" id="how">
      <div class="shell">
        <div class="section__head reveal">
          <span class="kicker">Three steps</span>
          <h2 class="section-title" style="margin-top:16px">From download to a real conversation.</h2>
        </div>

        <div class="how__grid">
          <div class="how__visual reveal">
            <div class="device" data-tilt>
              <div class="device__notch" aria-hidden="true"></div>
              <div class="device__screen">
                <div class="hmu-screen">
                  <div class="hmu-screen__top">
                    <strong>Requests</strong>
                    <span class="hmu-coin"><span aria-hidden="true"></span> 12</span>
                  </div>
                  <div class="hmu-card">
                    <div class="hmu-card__head">
                      <img src={u(sofia, 96, 96)} alt="" loading="lazy" />
                      <div>
                        <strong>Sofia, 27</strong>
                        <em>Verified · 3 km away</em>
                      </div>
                    </div>
                    <p class="hmu-card__msg">Saw you're into bouldering too. Real crag or the gym wall?</p>
                    <div class="hmu-card__actions">
                      <span class="hmu-pill hmu-pill--accept">Accept</span>
                      <span class="hmu-pill hmu-pill--later">Maybe later</span>
                    </div>
                  </div>
                  <p class="hmu-screen__hint">Requests skip the match queue.</p>
                </div>
              </div>
            </div>
          </div>

          <ol class="steps">
            <li class="step reveal">
              <span class="step__num">1</span>
              <div>
                <h3>Get verified</h3>
                <p>A quick selfie and ID check, reviewed by a real person on our team. There's no way around it, which is exactly the point.</p>
              </div>
            </li>
            <li class="step reveal" style="--reveal-delay:90ms">
              <span class="step__num">2</span>
              <div>
                <h3>Meet real people</h3>
                <p>Swipe a feed of verified profiles near you, inside the age range you set. Everyone you see cleared the same check you did.</p>
              </div>
            </li>
            <li class="step reveal" style="--reveal-delay:180ms">
              <span class="step__num">3</span>
              <div>
                <h3>Hit them up</h3>
                <p>Like someone? Send a chat request that lands at the top of their inbox, instead of waiting around on a maybe-match.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURES / HMU SPOTLIGHT
         ============================================================ -->
    <section class="section section--warm" id="features">
      <div class="shell">
        <div class="section__head reveal">
          <span class="kicker">What makes Spark different</span>
          <h2 class="section-title" style="margin-top:16px">Skip the match-and-pray. Just say hi.</h2>
          <p class="lead">Most apps make you both swipe right, then hope one of you breaks the silence. Spark lets you reach out first, so conversations actually start.</p>
        </div>

        <div class="spotlight__grid">
          <article class="tile tile--hmu reveal">
            <div class="tile__body">
              <h3>HMU: the request that gets read</h3>
              <p>Spend a few coins to send someone a real opening message. It lands above the noise, they accept, and you're talking. No mutual-swipe lottery required.</p>
            </div>
            <div class="hmu-demo" aria-hidden="true">
              <div class="hmu-bubble hmu-bubble--in">ok so the bouldering thing wasn't a line, you actually go?</div>
              <div class="hmu-bubble hmu-bubble--out">every saturday. come find out 🧗</div>
              <span class="hmu-demo__stamp">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                Request accepted in 6 minutes
              </span>
            </div>
          </article>

          <article class="tile reveal" style="--reveal-delay:90ms">
            <span class="tile__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 10.5 20 7v10l-4.5-3.5z"/><rect x="3" y="6" width="12.5" height="12" rx="3"/></svg></span>
            <h3>Calls, built in</h3>
            <p>Voice and video live inside Spark. Hear someone's laugh before you meet, and never have to hand over your number.</p>
          </article>

          <article class="tile reveal" style="--reveal-delay:180ms">
            <span class="tile__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <h3>On your terms</h3>
            <p>Set your age range and distance, and hide your profile whenever you want a break. You decide who gets to see you.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============================================================
         VERIFIED / REAL PEOPLE
         ============================================================ -->
    <section class="section" id="verified">
      <div class="shell">
        <div class="verified__grid">
          <div class="verified__copy">
            <span class="kicker reveal">Real people only</span>
            <h2 class="section-title reveal" style="margin-top:16px">No bots. No catfish.<br />No “wait, is this real?”</h2>
            <p class="lead reveal">Verification isn't a blue tick you buy. On Spark it's the front door, and there's no other way in.</p>
            <ul class="verified__list reveal">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Photo and government ID checked by a human, not a model.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Re-verification kicks in the moment a profile looks off.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Report or block in seconds. Every report gets looked at.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Your data is never sold. Ever.</li>
            </ul>
            <a href="/safety/" class="textlink verified__cta reveal">
              Read the safety guide
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="faces reveal" aria-label="A few verified Spark members">
            <figure><img src={u(amara, 420, 560)} alt="Amara, a verified member with auburn hair" loading="lazy" /></figure>
            <figure><img src={u(daniel, 420, 560)} alt="Daniel, a verified member in a blue shirt" loading="lazy" /></figure>
            <figure><img src={u(leila, 420, 560)} alt="Leila, a verified member smiling" loading="lazy" /></figure>
            <figure><img src={u(nadia, 420, 560)} alt="Nadia, a verified member in a striped shirt" loading="lazy" /></figure>
            <figure><img src={u(sofia, 760, 480)} alt="Sofia, a verified member laughing" loading="lazy" /></figure>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CTA BAND — the single rich / dark moment
         ============================================================ -->
    <section id="get">
      <div class="cta reveal">
        <div class="cta__glow" aria-hidden="true"></div>
        <div class="cta__inner">
          <h2 class="cta__title">Go meet someone real.</h2>
          <p class="cta__sub">Spark is free to download. Get verified in a day, and start talking to people who are exactly who they say they are.</p>
          <div class="cta__actions">
            <!-- TODO: swap href for the real App Store / Play Store URLs once published. -->
            <a class="store" href="#" aria-label="Download on the App Store">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 12.6c0-3.1 2.5-4.6 2.7-4.7-1.5-2.2-3.8-2.5-4.6-2.5-2-.2-3.8 1.2-4.8 1.2-1 0-2.5-1.1-4.2-1.1-2.2 0-4.2 1.3-5.3 3.2-2.3 4-.6 9.9 1.6 13.2 1.1 1.6 2.4 3.4 4.1 3.3 1.7-.1 2.3-1.1 4.3-1.1 2 0 2.6 1.1 4.4 1 1.8 0 2.9-1.6 4-3.2.5-.8.7-1.2 1.1-2.1-3-.9-3.3-4.7-3.3-5.2zM14.4 4c.9-1.1 1.5-2.6 1.4-4.1-1.3.1-2.9.9-3.8 2-.8.9-1.5 2.5-1.3 3.9 1.4.1 2.9-.7 3.7-1.8z"/></svg>
              <span><em>Download on the</em><strong>App Store</strong></span>
            </a>
            <a class="store" href="#" aria-label="Get it on Google Play">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 2.5v19l10-9.5L3 2.5z" fill="#00d2ff"/>
                <path d="M13 12 3 21.5l10.5-5.5L13 12z" fill="#22C55E"/>
                <path d="M13 12l.5-4-10.5-5.5L13 12z" fill="#ff4458"/>
                <path d="M21.5 11.1 17.5 8.8 13.5 12l4 3.2 4-2.3c1.5-.8 1.5-2.6 0-3.4z" fill="#FBBF24"/>
              </svg>
              <span><em>Get it on</em><strong>Google Play</strong></span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<!--
  Minimal client behaviour: staggered reveal-on-scroll and a gentle
  pointer tilt on the phone mockups. Everything no-ops under
  prefers-reduced-motion.
-->
<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Reveal-on-scroll
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if ('IntersectionObserver' in window && !reduce) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.14, rootMargin: '0px 0px -8% 0px' },
    );
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  // Gentle device tilt toward the pointer
  if (!reduce && window.matchMedia('(pointer: fine)').matches) {
    const tiltEls = Array.from(document.querySelectorAll<HTMLElement>('[data-tilt]'));
    let raf = 0;
    window.addEventListener(
      'pointermove',
      (ev) => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          const x = (ev.clientX / window.innerWidth - 0.5) * 2;
          const y = (ev.clientY / window.innerHeight - 0.5) * 2;
          tiltEls.forEach((el) => {
            el.style.transform = `perspective(1100px) rotateY(${x * 4}deg) rotateX(${y * -3}deg)`;
          });
          raf = 0;
        });
      },
      { passive: true },
    );
  }
</script>
