---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

/*
 * Datera-style redesign — vibrant, app-store-marketing energy (gradient
 * hero, bold rounded cards, screenshot showcase, FAQ accordion) over the
 * honest Luvmood copy. Per the project rule we DO NOT invent stats or
 * testimonials — Datera ships a counter row + a testimonial carousel; both
 * are replaced here with real trust/safety content.
 *
 * Every image is an explicit PLACEHOLDER (.ph) with a description of the
 * shot to drop in. Swap each one for a real screenshot / photo before launch.
 * Styles are scoped to this page so the other routes keep global.css.
 */
---

<Layout>
  <Nav />

  <main class="lp">
    <!-- ===================================================================
         HERO
         =================================================================== -->
    <section class="hero" id="top">
      <div class="hero__bg" aria-hidden="true">
        <span class="blob blob--a"></span>
        <span class="blob blob--b"></span>
        <span class="grid-fade"></span>
      </div>

      <div class="hero__inner shell">
        <div class="hero__copy">
          <span class="pill reveal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
            Photo-verified only
          </span>

          <h1 class="hero__title reveal" style="--d:80ms">
            Real people.<br /> <span class="grad">Real</span> conversations.
          </h1>

          <p class="hero__sub reveal" style="--d:160ms">
            Luvmood photo-verifies every profile by matching a fresh selfie to the
            photo you posted. Meet people who look like their pictures, then say hi
            without waiting around on a match.
          </p>

          <div class="hero__ctas reveal" style="--d:240ms">
            <a href="#get" class="btn btn--primary">Get the app</a>
            <a href="#how" class="btn btn--ghost">
              How it works
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="hero__trust reveal" style="--d:320ms">
            <!-- PLACEHOLDER: facepile — 3 small round photos of real, smiling,
                 diverse 20s–30s members (head-and-shoulders portraits). -->
            <span class="facepile" aria-hidden="true">
              <span class="ph ph--face"><span class="ph__t">Portrait</span></span>
              <span class="ph ph--face"><span class="ph__t">Portrait</span></span>
              <span class="ph ph--face"><span class="ph__t">Portrait</span></span>
            </span>
            <span><b>Verified profiles.</b> Free to join on iOS &amp; Android.</span>
          </div>
        </div>

        <div class="hero__stage reveal" style="--d:200ms">
          <div class="phone phone--lg" data-tilt>
            <span class="phone__notch" aria-hidden="true"></span>
            <!-- PLACEHOLDER: hero app screenshot — the Discover/swipe screen.
                 Full-bleed verified profile card (photo + name, age, "Verified"
                 badge, "2 km away"), Pass / Like buttons at the bottom. -->
            <div class="ph ph--shot">
              <div class="ph__inner">
                <span class="ph__icon">📱</span>
                <span class="ph__label">App screenshot — Discover feed<br/>(verified profile card + Pass / Like)</span>
              </div>
            </div>
          </div>

          <div class="floatcard floatcard--a" data-float>
            <!-- PLACEHOLDER: tiny round portrait (smiling woman, 20s). -->
            <span class="ph ph--face ph--sm"><span class="ph__t">Portrait</span></span>
            <div><strong>Amara liked you</strong><em>Verified · 4 km away</em></div>
          </div>
          <div class="floatcard floatcard--b" data-float="b">
            <!-- PLACEHOLDER: tiny round portrait (smiling man, 20s). -->
            <span class="ph ph--face ph--sm"><span class="ph__t">Portrait</span></span>
            <div><strong>Daniel sent a request</strong><em>“Coffee this week? ☕”</em></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         TRUST STRIP  (replaces Datera's fake-number counter row)
         =================================================================== -->
    <section class="trust shell">
      <div class="trust__item reveal">
        <span class="trust__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg></span>
        <div><strong>Photo verified</strong><span>Selfie matched to your profile photo</span></div>
      </div>
      <div class="trust__item reveal" style="--d:90ms">
        <span class="trust__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M15 9 9 15M9 9l6 6"/></svg></span>
        <div><strong>Block &amp; report fast</strong><span>Two taps, and we act on it</span></div>
      </div>
      <div class="trust__item reveal" style="--d:180ms">
        <span class="trust__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
        <div><strong>Real people near you</strong><span>Nobody you can't actually meet</span></div>
      </div>
    </section>

    <!-- ===================================================================
         HOW IT WORKS
         =================================================================== -->
    <section class="section" id="how">
      <div class="shell">
        <div class="head reveal">
          <span class="eyebrow">Three steps</span>
          <h2 class="h2">From download to a conversation that actually starts.</h2>
        </div>

        <div class="steps">
          <article class="stepcard reveal">
            <span class="stepcard__n">1</span>
            <h3>Get photo-verified</h3>
            <p>A quick selfie matched against the photo on your profile. Takes a
              minute and adds a Photo&nbsp;verified badge.</p>
          </article>
          <article class="stepcard reveal" style="--d:90ms">
            <span class="stepcard__n">2</span>
            <h3>Meet real people</h3>
            <p>Swipe a feed of verified profiles near you, inside the age range
              you set. Everyone cleared the same check you did.</p>
          </article>
          <article class="stepcard reveal" style="--d:180ms">
            <span class="stepcard__n">3</span>
            <h3>Hit them up</h3>
            <p>Like someone? Send a chat request that lands at the top of their
              inbox, instead of waiting on a maybe-match.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         FEATURE — HMU (forward)
         =================================================================== -->
    <section class="section section--tint" id="features">
      <div class="shell feature">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--pink">HMU · Hit me up</span>
          <h2 class="h2">Skip the match-and-pray. Just say hi.</h2>
          <p class="lead">Most apps make you both swipe right, then hope someone
            breaks the silence. On Luvmood you spend a few coins to send a real
            opening message — it lands above the noise, they accept, you're talking.</p>
          <ul class="ticks">
            <li>No mutual-swipe required to send a request.</li>
            <li>They see your name, photo, and message — they decide.</li>
            <li>Coin cost keeps the inbox quality high. No spam.</li>
          </ul>
        </div>
        <div class="feature__visual reveal" style="--d:120ms">
          <div class="phone" data-tilt>
            <span class="phone__notch" aria-hidden="true"></span>
            <!-- PLACEHOLDER: HMU / Requests screen — an incoming chat request
                 card (small portrait + name/age + "Verified · 1 km", the
                 opening message, Accept / Maybe later buttons), coin balance
                 in the top corner. -->
            <div class="ph ph--shot">
              <div class="ph__inner"><span class="ph__icon">💬</span><span class="ph__label">App screenshot — Requests<br/>(chat request + Accept / Maybe later)</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         FEATURE — Calls (reverse)
         =================================================================== -->
    <section class="section">
      <div class="shell feature feature--reverse">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--violet">Voice &amp; video</span>
          <h2 class="h2">Hear the laugh before you meet.</h2>
          <p class="lead">Voice and video calls live inside Luvmood. Take the
            awkwardness out of the first meet, and never hand your number to a stranger.</p>
          <ul class="ticks">
            <li>Calls only after you've matched or accepted a request.</li>
            <li>Your number stays private. Always.</li>
            <li>End the call any time, no hard feelings.</li>
          </ul>
        </div>
        <div class="feature__visual reveal" style="--d:120ms">
          <div class="phone" data-tilt>
            <span class="phone__notch" aria-hidden="true"></span>
            <!-- PLACEHOLDER: in-call screen — a full-bleed portrait of the
                 person being called, their name + call timer (02:41) at top,
                 mute / speaker / red end-call buttons at the bottom. -->
            <div class="ph ph--shot">
              <div class="ph__inner"><span class="ph__icon">📞</span><span class="ph__label">App screenshot — Video call<br/>(portrait + timer + call controls)</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         FEATURE — Vibes (forward)
         =================================================================== -->
    <section class="section section--tint">
      <div class="shell feature">
        <div class="feature__copy reveal">
          <span class="eyebrow eyebrow--pink">Vibes</span>
          <h2 class="h2">Drop a vibe. See who's around.</h2>
          <p class="lead">Post a one-line vibe — what you're doing, what you're up
            for, where you are. People who match send a chat request. The easiest
            way to start something casual without the whole swipe ritual.</p>
          <ul class="ticks">
            <li>Vibes expire after 24 hours — no old posts haunting you.</li>
            <li>Only verified people can post or reply.</li>
            <li>Filtered to your age range and people you'd actually meet.</li>
          </ul>
        </div>
        <div class="feature__visual reveal" style="--d:120ms">
          <div class="phone" data-tilt>
            <span class="phone__notch" aria-hidden="true"></span>
            <!-- PLACEHOLDER: Vibes feed — a vertical list of 2–3 vibe cards,
                 each with a small portrait, name/age, distance + time, a
                 one-line status ("Free Sunday, museum or beach?") and a
                 "Hit her up →" button. -->
            <div class="ph ph--shot">
              <div class="ph__inner"><span class="ph__icon">⚡</span><span class="ph__label">App screenshot — Vibes feed<br/>(one-line status cards + Hit up)</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         SCREENSHOT SHOWCASE  (Datera signature — a row of phone screens)
         =================================================================== -->
    <section class="section showcase">
      <div class="shell">
        <div class="head reveal">
          <span class="eyebrow">A look inside</span>
          <h2 class="h2">Built to feel good in the hand.</h2>
        </div>

        <div class="showcase__rail">
          <div class="phone phone--rail reveal">
            <span class="phone__notch" aria-hidden="true"></span>
            <div class="ph ph--shot"><div class="ph__inner"><span class="ph__icon">🔥</span><span class="ph__label">Discover / swipe deck</span></div></div>
          </div>
          <div class="phone phone--rail phone--up reveal" style="--d:80ms">
            <span class="phone__notch" aria-hidden="true"></span>
            <div class="ph ph--shot"><div class="ph__inner"><span class="ph__icon">🗺️</span><span class="ph__label">Nearby map — people around you</span></div></div>
          </div>
          <div class="phone phone--rail reveal" style="--d:160ms">
            <span class="phone__notch" aria-hidden="true"></span>
            <div class="ph ph--shot"><div class="ph__inner"><span class="ph__icon">💬</span><span class="ph__label">Chat with voice / video</span></div></div>
          </div>
          <div class="phone phone--rail phone--up reveal" style="--d:240ms">
            <span class="phone__notch" aria-hidden="true"></span>
            <div class="ph ph--shot"><div class="ph__inner"><span class="ph__icon">👤</span><span class="ph__label">Profile with Verified badge</span></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         SAFETY / REAL PEOPLE  (replaces Datera's testimonial carousel)
         =================================================================== -->
    <section class="section" id="verified">
      <div class="shell">
        <div class="head reveal">
          <span class="eyebrow">Real people only</span>
          <h2 class="h2">No bots. No catfish. No “wait, is this real?”</h2>
          <p class="lead lead--center">Verification isn't a blue tick you buy. On
            Luvmood it's the front door — there's no other way in.</p>
        </div>

        <div class="cards">
          <article class="card reveal">
            <span class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg></span>
            <h3>Face-match on the way in</h3>
            <p>A fresh selfie is matched to your profile photo. Change your profile
              photo later and the check re-runs.</p>
          </article>
          <article class="card reveal" style="--d:90ms">
            <span class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg></span>
            <h3>Block in two taps</h3>
            <p>You never have to explain. Blocked profiles disappear from every
              feed, including chat history.</p>
          </article>
          <article class="card reveal" style="--d:180ms">
            <span class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <h3>You set the limits</h3>
            <p>Age range, distance, and visibility are in your hands. Pause your
              profile whenever you need a break.</p>
          </article>
          <article class="card reveal" style="--d:270ms">
            <span class="card__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <h3>Reports reach a human</h3>
            <p>Every report gets looked at. Repeat offenders get banned across all
              their accounts. Your data is never sold.</p>
          </article>
        </div>

        <!-- PLACEHOLDER: a face wall — 5 real, diverse, verified-looking member
             portraits in a tidy collage (mix of portrait + one wider shot). -->
        <div class="facewall reveal" aria-label="A few Luvmood members">
          <span class="ph ph--portrait"><span class="ph__t">Member portrait</span></span>
          <span class="ph ph--portrait"><span class="ph__t">Member portrait</span></span>
          <span class="ph ph--portrait"><span class="ph__t">Member portrait</span></span>
          <span class="ph ph--portrait"><span class="ph__t">Member portrait</span></span>
          <span class="ph ph--wide"><span class="ph__t">Member portrait (wide)</span></span>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         FAQ  (Datera ships an accordion — kept, with honest answers)
         =================================================================== -->
    <section class="section section--tint" id="faq">
      <div class="shell faq">
        <div class="head reveal">
          <span class="eyebrow">Good questions</span>
          <h2 class="h2">Before you download.</h2>
        </div>

        <div class="faq__list reveal">
          <details class="faq__item">
            <summary>Is Luvmood free?<span class="faq__chev" aria-hidden="true"></span></summary>
            <p>Yes — it's free to download, get verified, swipe, and match. Coins are
              optional and only used for extras like sending a chat request without a match.</p>
          </details>
          <details class="faq__item">
            <summary>What does “photo-verified” actually mean?<span class="faq__chev" aria-hidden="true"></span></summary>
            <p>Before you can use the app, you take a fresh selfie and we match it
              against the photo on your profile. It's how we keep out catfish and bots,
              and it's why every profile you see carries a Verified badge.</p>
          </details>
          <details class="faq__item">
            <summary>Is my location shared with other people?<span class="faq__chev" aria-hidden="true"></span></summary>
            <p>No. Distances are approximate and the map only ever shows you an
              area, never anyone's exact spot. Your real coordinates never leave our servers.</p>
          </details>
          <details class="faq__item">
            <summary>How do calls work?<span class="faq__chev" aria-hidden="true"></span></summary>
            <p>Voice and video calls happen inside the app, only after you've matched
              or accepted a request. You never have to share your phone number.</p>
          </details>
          <details class="faq__item">
            <summary>Which devices is it on?<span class="faq__chev" aria-hidden="true"></span></summary>
            <p>iPhone and Android. Download links are at the bottom of this page.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- ===================================================================
         DOWNLOAD CTA
         =================================================================== -->
    <section id="get">
      <div class="cta shell reveal">
        <div class="cta__bg" aria-hidden="true"><span class="blob blob--c"></span></div>
        <div class="cta__inner">
          <h2 class="cta__title">Go meet someone real.</h2>
          <p class="cta__sub">Free to download. Get photo-verified in a minute, and
            start meeting people who look like their pictures.</p>
          <div class="cta__stores">
            <!-- TODO: swap href for the real App Store / Play Store URLs once published. -->
            <a class="store" href="#" aria-label="Download on the App Store">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 12.6c0-3.1 2.5-4.6 2.7-4.7-1.5-2.2-3.8-2.5-4.6-2.5-2-.2-3.8 1.2-4.8 1.2-1 0-2.5-1.1-4.2-1.1-2.2 0-4.2 1.3-5.3 3.2-2.3 4-.6 9.9 1.6 13.2 1.1 1.6 2.4 3.4 4.1 3.3 1.7-.1 2.3-1.1 4.3-1.1 2 0 2.6 1.1 4.4 1 1.8 0 2.9-1.6 4-3.2.5-.8.7-1.2 1.1-2.1-3-.9-3.3-4.7-3.3-5.2zM14.4 4c.9-1.1 1.5-2.6 1.4-4.1-1.3.1-2.9.9-3.8 2-.8.9-1.5 2.5-1.3 3.9 1.4.1 2.9-.7 3.7-1.8z"/></svg>
              <span><em>Download on the</em><strong>App Store</strong></span>
            </a>
            <a class="store" href="#" aria-label="Get it on Google Play">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 2.5v19l10-9.5L3 2.5z" fill="#00d2ff"/><path d="M13 12 3 21.5l10.5-5.5L13 12z" fill="#22C55E"/><path d="M13 12l.5-4-10.5-5.5L13 12z" fill="#ff4458"/><path d="M21.5 11.1 17.5 8.8 13.5 12l4 3.2 4-2.3c1.5-.8 1.5-2.6 0-3.4z" fill="#FBBF24"/></svg>
              <span><em>Get it on</em><strong>Google Play</strong></span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================ TOKENS ============================ */
  .lp {
    --pink: #fd297b;
    --violet: #7c3aed;
    --ink: #1a1020;
    --muted: #6b5a76;
    --line: rgba(26,16,32,0.10);
    --grad: linear-gradient(115deg, #fd297b 0%, #b5269e 45%, #7c3aed 100%);
    --tint: #fbf3fa;
    color: var(--ink);
    font-family: 'Hanken Grotesk', system-ui, sans-serif;
    overflow-x: clip;
  }
  .lp .shell { width: min(1140px, 92vw); margin-inline: auto; }
  .lp h1, .lp h2, .lp h3 { font-family: 'Bricolage Grotesque', 'Hanken Grotesk', sans-serif; letter-spacing: -0.02em; }
  .lp .section { padding: clamp(64px, 9vw, 116px) 0; }
  .lp .section--tint { background: var(--tint); }
  .lp .h2 { font-size: clamp(28px, 4.4vw, 46px); line-height: 1.05; font-weight: 700; margin: 14px 0 0; }
  .lp .eyebrow { display: inline-block; font-size: 13px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--violet); }
  .lp .eyebrow--pink { color: var(--pink); }
  .lp .eyebrow--violet { color: var(--violet); }
  .lp .head { max-width: 740px; }
  .lp .head .lead--center { margin-inline: auto; }
  .lp .lead { font-size: clamp(16px, 1.6vw, 19px); line-height: 1.6; color: var(--muted); margin-top: 16px; max-width: 60ch; }
  .lp .lead--center { text-align: center; }
  .lp .grad { background: var(--grad); -webkit-background-clip: text; background-clip: text; color: transparent; }

  /* ============================ BUTTONS ============================ */
  .lp .btn { display: inline-flex; align-items: center; gap: 9px; font-weight: 700; font-size: 16px; border-radius: 999px; padding: 14px 26px; text-decoration: none; transition: transform .18s ease, box-shadow .18s ease; }
  .lp .btn svg { width: 18px; height: 18px; }
  .lp .btn--primary { background: var(--grad); color: #fff; box-shadow: 0 14px 30px -10px rgba(253,41,123,0.6); }
  .lp .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 20px 40px -10px rgba(253,41,123,0.7); }
  .lp .btn--ghost { background: #fff; color: var(--ink); border: 1.5px solid var(--line); }
  .lp .btn--ghost:hover { transform: translateY(-2px); border-color: var(--pink); color: var(--pink); }
  .lp .pill { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; color: var(--violet); background: #fff; border: 1.5px solid rgba(124,58,237,0.25); border-radius: 999px; padding: 7px 14px; box-shadow: 0 6px 18px -10px rgba(124,58,237,0.5); }
  .lp .pill svg { width: 15px; height: 15px; }

  /* ============================ PLACEHOLDERS ============================ */
  .lp .ph { position: relative; display: grid; place-items: center; text-align: center;
    background: linear-gradient(135deg, rgba(253,41,123,0.07), rgba(124,58,237,0.09));
    border: 2px dashed rgba(124,58,237,0.34); color: #7a5a86; border-radius: 18px; padding: 16px; }
  .lp .ph__inner { display: grid; gap: 8px; max-width: 26ch; }
  .lp .ph__icon { font-size: 30px; }
  .lp .ph__label { font-size: 12.5px; line-height: 1.4; font-weight: 700; }
  .lp .ph__t { font-size: 10px; font-weight: 800; letter-spacing: .04em; color: #8a6a96; opacity: .9; }
  .lp .ph--shot { width: 100%; height: 100%; border-radius: 30px; }
  .lp .ph--face { width: 100%; height: 100%; border-radius: 999px; padding: 0; }
  .lp .ph--portrait { aspect-ratio: 3/4; }
  .lp .ph--wide { aspect-ratio: 16/11; }

  /* ============================ PHONE FRAME ============================ */
  .lp .phone { position: relative; width: 264px; aspect-ratio: 9/19.2; background: #15101c; border-radius: 38px; padding: 9px; box-shadow: 0 40px 80px -30px rgba(124,58,237,0.55), 0 8px 22px -12px rgba(0,0,0,0.4); }
  .lp .phone--lg { width: 300px; }
