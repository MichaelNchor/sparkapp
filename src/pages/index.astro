<!-- Tick fallback colour for browsers without mask support: paint via bg already; ensure visible glyph. -->
<style>
  /* The check glyph uses CSS mask over the gradient; the gradient fill is the
     mask source colour, so no extra fill needed. Left intentionally minimal. */
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Reveal-on-scroll
  const els = document.querySelectorAll<HTMLElement>('.reveal');
  if ('IntersectionObserver' in window && !reduce) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-visible'));
  }

  // Gentle device tilt toward the pointer
  if (!reduce && window.matchMedia('(pointer: fine)').matches) {
    const tilt = Array.from(document.querySelectorAll<HTMLElement>('[data-tilt]'));
    let raf = 0;
    window.addEventListener('pointermove', (ev) => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        const x = (ev.clientX / window.innerWidth - 0.5) * 2;
        const y = (ev.clientY / window.innerHeight - 0.5) * 2;
        tilt.forEach((el) => { el.style.transform = `perspective(1100px) rotateY(${x * 3}deg) rotateX(${y * -2.2}deg)`; });
        raf = 0;
      });
    }, { passive: true });
  }
</script>
