            </div>
          </div>
        </div>

        <div class="float-card float-card--match">
          <span class="float-card__avatar"></span>
          <div>
            <strong>Match Activity</strong>
            <p>Cristina Marin <em>· Abuja, Nigeria</em></p>
          </div>
