        <p class="reveal">
          Every profile passes manual photo + ID review before they can swipe. The result: a feed of real people, not noise.
        </p>

        <div class="store-row reveal">
          <!-- TODO: replace href with real App Store / Play Store URLs once published. -->
          <a class="store-btn" href="#" aria-label="Download on the App Store">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M17.5 12.6c0-3.1 2.5-4.6 2.7-4.7-1.5-2.2-3.8-2.5-4.6-2.5-2-.2-3.8 1.2-4.8 1.2-1 0-2.5-1.1-4.2-1.1-2.2 0-4.2 1.3-5.3 3.2-2.3 4-.6 9.9 1.6 13.2 1.1 1.6 2.4 3.4 4.1 3.3 1.7-.1 2.3-1.1 4.3-1.1 2 0 2.6 1.1 4.4 1 1.8 0 2.9-1.6 4-3.2.5-.8.7-1.2 1.1-2.1-3-.9-3.3-4.7-3.3-5.2zM14.4 4c.9-1.1 1.5-2.6 1.4-4.1-1.3.1-2.9.9-3.8 2-.8.9-1.5 2.5-1.3 3.9 1.4.1 2.9-.7 3.7-1.8z"/></svg>
            <span><em>Download on the</em><strong>App Store</strong></span>
          </a>
          <a class="store-btn" href="#" aria-label="Get it on Google Play">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
              <defs>
                <linearGradient id="playGrad1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#00d2ff"/><stop offset="100%" stop-color="#3a7bd5"/></linearGradient>
                <linearGradient id="playGrad2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#ff4458"/><stop offset="100%" stop-color="#ffd200"/></linearGradient>
              </defs>
              <path d="M3 2.5v19l10-9.5L3 2.5z" fill="url(#playGrad1)"/>
              <path d="M13 12L3 21.5l10.5-5.5L13 12z" fill="#22C55E"/>
              <path d="M13 12l.5-4-10.5-5.5L13 12z" fill="url(#playGrad2)"/>
              <path d="M21.5 11.1L17.5 8.8 13.5 12l4 3.2 4-2.3c1.5-.8 1.5-2.6 0-3.4z" fill="#FBBF24"/>
            </svg>
            <span><em>Get it on</em><strong>Google Play</strong></span>
          </a>
        </div>
      </div>

      <div class="verified__visual reveal" data-parallax="0.08">
        <div class="verified__people"></div>
        <div class="verified__bubble">
          <span class="verified__bubble-avatar"></span>
          <div>
            <strong>Hello, How Are You? Sweet?</strong>
