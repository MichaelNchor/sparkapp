---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

/*
 * Real, verified Unsplash portraits used inside the product mockups so
 * the page shows real faces, not gradient placeholders. IDs were checked
 * to resolve (HTTP 200) before being committed.
 */
const u = (id: string, w = 640, h = 0) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&q=80&w=${w}${h ? `&h=${h}` : ''}`;

const maya   = '1525134479668-1bee5c7c6845'; // denim jacket, golden-hour smile
const amara  = '1524550158212-33f2ff985344'; // auburn hair, calm smile
const daniel = '1600603406200-5b2a104684ac'; // blue tee, relaxed
const sofia  = '1494790108377-be9c29b29330'; // laughing, red top
const leila  = '1567516364473-233c4b6fcfbe'; // soft smile, looking down
const nadia  = '1544005313-94ddf0286df2';    // striped shirt, serene
const kofi   = '1531123897727-8f129e1688ce'; // warm portrait, used in Vibes / Calls
---

<Layout>
  <Nav />

  <main>
    <!-- ============================================================
         HERO — editorial. Big claim, photo-led right rail, two CTAs.
         ============================================================ -->
    <section class="hero" id="top">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="hero__inner">
        <div class="hero__copy">
          <span class="kicker reveal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
            Photo-verified only
          </span>

          <h1 class="hero__title reveal" style="--reveal-delay:80ms">
            Real people.<br class="hero-br" /> <span class="em-pink">Real</span> conversations.
          </h1>

          <p class="hero__sub reveal" style="--reveal-delay:160ms">
            Luvmood photo-verifies every profile by matching a fresh selfie against the photo you already posted. Meet people who look like their pictures — then say hi without waiting for a match.
          </p>

          <div class="hero__ctas reveal" style="--reveal-delay:240ms">
            <a href="#get" class="btn btn--primary">Get the app</a>
            <a href="#how" class="textlink">
              See how it works
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="hero__trust reveal" style="--reveal-delay:320ms">
            <span class="facepile" aria-hidden="true">
              <img src={u(amara, 80, 80)} alt="" loading="lazy" />
              <img src={u(daniel, 80, 80)} alt="" loading="lazy" />
              <img src={u(sofia, 80, 80)} alt="" loading="lazy" />
            </span>
            <span><b>Verified profiles.</b> Free to join on iOS &amp; Android.</span>
          </div>
        </div>

        <div class="hero__stage reveal" style="--reveal-delay:200ms">
          <div class="device" data-tilt>
            <div class="device__notch" aria-hidden="true"></div>
            <div class="device__screen">
              <div class="discover">
                <img src={u(maya, 720, 1040)} alt="Maya, 26, smiling in a field at golden hour" loading="eager" />
                <div class="discover__scrim" aria-hidden="true"></div>
                <span class="discover__verified">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
                  Verified
                </span>
                <div class="discover__meta">
                  <h4>Maya, 26</h4>
                  <p>
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                    2 km away
                  </p>
                </div>
                <div class="discover__actions" aria-hidden="true">
                  <span class="discover__btn discover__btn--pass"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></span>
                  <span class="discover__btn discover__btn--like"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-9.5-8.6C.8 9.3 2.5 5.3 6.2 5.3c2.1 0 3.6 1.2 5.8 3.6 2.2-2.4 3.7-3.6 5.8-3.6 3.7 0 5.4 4 3.7 7.1C19 16.5 12 21 12 21Z"/></svg></span>
                </div>
              </div>
            </div>
          </div>

          <div class="floatcard hero__float--match" data-float>
            <img src={u(amara, 80, 80)} alt="" loading="lazy" />
            <div>
              <strong>Amara liked you</strong>
              <em>Verified · 4 km away</em>
            </div>
          </div>

          <div class="floatcard hero__float--hmu" data-float="b">
            <img src={u(daniel, 80, 80)} alt="" loading="lazy" />
            <div>
              <strong>Daniel sent a request</strong>
              <span class="hmu-mini-msg">“Coffee this week? ☕”</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         TRUST STRIP
         ============================================================ -->
    <section class="trust">
      <div class="trust__inner">
        <div class="trust__item reveal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg>
          <div><strong>Photo verified</strong><span>Selfie matched to your profile photo</span></div>
        </div>
        <div class="trust__item reveal" style="--reveal-delay:100ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M15 9 9 15M9 9l6 6"/></svg>
          <div><strong>Block &amp; report fast</strong><span>Two taps, and we act on it</span></div>
        </div>
        <div class="trust__item reveal" style="--reveal-delay:200ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.3-7-11a7 7 0 0 1 14 0c0 5.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
          <div><strong>Real people near you</strong><span>Nobody you can't actually meet</span></div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS
         ============================================================ -->
    <section class="section" id="how">
      <div class="shell">
        <div class="section__head reveal">
          <span class="kicker">Three steps</span>
          <h2 class="section-title" style="margin-top:18px">From download to a conversation that actually starts.</h2>
        </div>

        <div class="how__grid">
          <div class="how__visual reveal">
            <div class="device" data-tilt>
              <div class="device__notch" aria-hidden="true"></div>
              <div class="device__screen">
                <div class="hmu-screen">
                  <div class="hmu-screen__top">
                    <strong>Requests</strong>
                    <span class="hmu-coin"><span aria-hidden="true"></span> 12</span>
                  </div>
                  <div class="hmu-card">
                    <div class="hmu-card__head">
                      <img src={u(sofia, 96, 96)} alt="" loading="lazy" />
                      <div>
                        <strong>Sofia, 27</strong>
                        <em>Verified · 3 km away</em>
                      </div>
                    </div>
                    <p class="hmu-card__msg">Saw you're into bouldering too. Real crag or the gym wall?</p>
                    <div class="hmu-card__actions">
                      <span class="hmu-pill hmu-pill--accept">Accept</span>
                      <span class="hmu-pill hmu-pill--later">Maybe later</span>
                    </div>
                  </div>
                  <p class="hmu-screen__hint">Requests skip the match queue.</p>
                </div>
              </div>
            </div>
          </div>

          <ol class="steps">
            <li class="step reveal">
              <span class="step__num">1</span>
              <div>
                <h3>Get photo-verified</h3>
                <p>A quick selfie that we match against the photo on your profile. Takes a minute, and adds a Photo verified badge to your profile.</p>
              </div>
            </li>
            <li class="step reveal" style="--reveal-delay:90ms">
              <span class="step__num">2</span>
              <div>
                <h3>Meet real people</h3>
                <p>Swipe a feed of verified profiles near you, inside the age range you set. Everyone you see cleared the same check you did.</p>
              </div>
            </li>
            <li class="step reveal" style="--reveal-delay:180ms">
              <span class="step__num">3</span>
              <div>
                <h3>Hit them up</h3>
                <p>Like someone? Send a chat request that lands at the top of their inbox, instead of waiting around on a maybe-match.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE 1 — HMU (the signature feature). Cream band.
         ============================================================ -->
    <section class="section section--cream" id="features">
      <div class="shell">
        <div class="feature reveal">
          <div class="feature__copy">
            <p class="feature__eyebrow">HMU · Hit me up</p>
            <h2 class="feature__title">Skip the match-and-pray. Just say hi.</h2>
            <p class="feature__body">
              Most apps make you both swipe right, then hope one of you breaks the silence. On Luvmood, you can spend a few coins to send a real opening message — it lands above the noise, they accept, and you're talking.
            </p>
            <ul class="feature__points">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> No mutual-swipe required to send a request.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> They see your name, photo, and message — they decide.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Coin cost keeps the inbox quality high. No spam.</li>
            </ul>
          </div>

          <div class="feature__visual">
            <div class="device" data-tilt>
              <div class="device__notch" aria-hidden="true"></div>
              <div class="device__screen">
                <div class="hmu-screen">
                  <div class="hmu-screen__top">
                    <strong>Inbox</strong>
                    <span class="hmu-coin"><span aria-hidden="true"></span> 12</span>
                  </div>
                  <div class="hmu-card">
                    <div class="hmu-card__head">
                      <img src={u(daniel, 96, 96)} alt="" loading="lazy" />
                      <div>
                        <strong>Daniel, 28</strong>
                        <em>Verified · 1 km away</em>
                      </div>
                    </div>
                    <p class="hmu-card__msg">ok so the bouldering thing wasn't a line — you actually go?</p>
                    <div class="hmu-card__actions">
                      <span class="hmu-pill hmu-pill--accept">Accept</span>
                      <span class="hmu-pill hmu-pill--later">Maybe later</span>
                    </div>
                  </div>
                  <p class="hmu-screen__hint">Accepted in 6 minutes.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE 2 — Calls built in. Reverse layout.
         ============================================================ -->
    <section class="section">
      <div class="shell">
        <div class="feature feature--reverse reveal">
          <div class="feature__copy">
            <p class="feature__eyebrow">Voice &amp; video</p>
            <h2 class="feature__title">Hear the laugh before you meet.</h2>
            <p class="feature__body">
              Voice and video calls live inside Luvmood. Take the awkwardness out of the first meet — and never have to hand over your number to a stranger.
            </p>
            <ul class="feature__points">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Calls only after you've both matched or accepted a request.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Your number stays private. Always.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> End the call any time, no hard feelings.</li>
            </ul>
          </div>

          <div class="feature__visual">
            <div class="device" data-tilt>
              <div class="device__notch" aria-hidden="true"></div>
              <div class="device__screen">
                <div class="call-screen">
                  <p class="call-screen__name">Sofia</p>
                  <p class="call-screen__timer">02:41</p>
                  <img src={u(sofia, 256, 256)} alt="" loading="lazy" />
                  <div class="call-screen__bar" aria-hidden="true">
                    <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M9 9v6M15 9v6M3 5l18 14"/></svg></span>
                    <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/></svg></span>
                    <span class="end"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE 3 — Vibes. Cream band. Forward layout.
         ============================================================ -->
    <section class="section section--cream">
      <div class="shell">
        <div class="feature reveal">
          <div class="feature__copy">
            <p class="feature__eyebrow">Vibes</p>
            <h2 class="feature__title">Drop a vibe. See who's around.</h2>
            <p class="feature__body">
              Post a one-line vibe — what you're doing, what you're up for, where you are. People who match send a chat request. It's the easiest way to start something casual without doing the whole swipe ritual.
            </p>
            <ul class="feature__points">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Vibes expire after 24 hours — no old posts haunting you.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Only verified people can post or reply.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Filtered to your age range and the people you'd actually meet.</li>
            </ul>
          </div>

          <div class="feature__visual">
            <div class="device" data-tilt>
              <div class="device__notch" aria-hidden="true"></div>
              <div class="device__screen">
                <div class="vibes-screen">
                  <div class="vibe-card">
                    <img src={u(leila, 80, 80)} alt="" loading="lazy" />
                    <div class="vibe-card__body">
                      <div class="vibe-card__head"><strong>Leila, 25</strong><em>2 km · 1h</em></div>
                      <p class="vibe-card__text">Free Sunday afternoon, museum or beach?</p>
                      <span class="vibe-card__cta">Hit her up <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
                    </div>
                  </div>
                  <div class="vibe-card">
                    <img src={u(kofi, 80, 80)} alt="" loading="lazy" />
                    <div class="vibe-card__body">
                      <div class="vibe-card__head"><strong>Kofi, 29</strong><em>4 km · 3h</em></div>
                      <p class="vibe-card__text">Coffee at Vida e Caffe in an hour, anyone?</p>
                      <span class="vibe-card__cta">Hit him up <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
                    </div>
                  </div>
                  <div class="vibe-card">
                    <img src={u(nadia, 80, 80)} alt="" loading="lazy" />
                    <div class="vibe-card__body">
                      <div class="vibe-card__head"><strong>Nadia, 26</strong><em>1 km · 5h</em></div>
                      <p class="vibe-card__text">First time at the gym today, no judgement plz</p>
                      <span class="vibe-card__cta">Hit her up <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         VERIFIED / REAL PEOPLE — the trust story with the face wall
         ============================================================ -->
    <section class="section" id="verified">
      <div class="shell">
        <div class="verified__grid">
          <div class="verified__copy">
            <span class="kicker reveal">Real people only</span>
            <h2 class="section-title reveal" style="margin-top:18px">No bots. No catfish.<br />No “wait, is this real?”</h2>
            <p class="lead reveal">Verification isn't a blue tick you buy. On Luvmood it's the front door — there's no other way in.</p>
            <ul class="verified__list reveal">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Fresh selfie matched to your profile photo by our face-match check.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Every photo passes an automated moderation check; profile-photo changes re-run the check.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Report or block in seconds. Every report gets looked at.</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Your data is never sold. Ever.</li>
            </ul>
            <a href="/safety/" class="textlink verified__cta reveal">
              Read the safety guide
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <div class="faces reveal" aria-label="A few verified Luvmood members">
            <figure><img src={u(amara, 420, 560)} alt="Amara, a verified member with auburn hair" loading="lazy" /></figure>
            <figure><img src={u(daniel, 420, 560)} alt="Daniel, a verified member in a blue shirt" loading="lazy" /></figure>
            <figure><img src={u(leila, 420, 560)} alt="Leila, a verified member smiling" loading="lazy" /></figure>
            <figure><img src={u(nadia, 420, 560)} alt="Nadia, a verified member in a striped shirt" loading="lazy" /></figure>
            <figure><img src={u(sofia, 760, 480)} alt="Sofia, a verified member laughing" loading="lazy" /></figure>
          </div>
        </div>

        <!-- Safe-by-design strip: three quiet cards under the face wall -->
        <div class="safety-strip">
          <div class="safety-card reveal">
            <div class="safety-card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg></div>
            <h3>Block in two taps</h3>
            <p>You never have to explain. Blocked profiles disappear from every feed, including chat history.</p>
          </div>
          <div class="safety-card reveal" style="--reveal-delay:90ms">
            <div class="safety-card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div>
            <h3>You set the limits</h3>
            <p>Age range, distance, and visibility — all in your hands. Pause your profile when you need a break.</p>
          </div>
          <div class="safety-card reveal" style="--reveal-delay:180ms">
            <div class="safety-card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5z"/><path d="m9 12 2 2 4-4"/></svg></div>
            <h3>Moderation that's actually staffed</h3>
            <p>Every report goes to a human, not a bot. Repeat offenders get banned across all their accounts.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CTA BAND — the single rich / dark moment
         ============================================================ -->
    <section id="get">
      <div class="cta reveal">
        <div class="cta__glow" aria-hidden="true"></div>
        <div class="cta__inner">
          <h2 class="cta__title">Go meet someone real.</h2>
          <p class="cta__sub">Luvmood is free to download. Get photo-verified in a minute, and start meeting people who look like their pictures.</p>
          <div class="cta__actions">
            <!-- TODO: swap href for the real App Store / Play Store URLs once published. -->
            <a class="store" href="#" aria-label="Download on the App Store">
