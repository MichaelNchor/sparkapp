---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- ============================================================
       HERO — dark navy with a Three.js heart particle field
       behind the headline. Canvas is pointer-events:none so it
       never interferes with the UI above.
       ============================================================ -->
  <header class="hero" id="home">
    <canvas id="hero-canvas" aria-hidden="true"></canvas>

    <Nav />

    <div class="hero__inner">
      <div class="hero__copy reveal">
        <h1 class="hero__title">
          When You Would Like<br />
          To Go On A <span class="hero__title-accent">Dating?</span>
        </h1>
        <p class="hero__sub">An application aimed at singles looking for a real relationship.</p>

        <div class="hero__ctas">
          <a href="#download" class="btn btn--primary">Get Started</a>
          <button type="button" class="hero__video" id="watchIntro" aria-label="Watch intro video">
            <span class="hero__video-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
            <span class="hero__video-text">
              <strong>Watch</strong>
              <em>Intro Video</em>
            </span>
          </button>
        </div>
      </div>

      <aside class="hero__stat reveal reveal--right">
        <div class="hero__stat-num">8.6m</div>
        <div class="hero__stat-row">
          <span class="hero__stat-avatars" aria-hidden="true">
            <span style="--c1:#fd297b;--c2:#ff5864"></span>
            <span style="--c1:#A78BFA;--c2:#fd297b"></span>
            <span style="--c1:#22C55E;--c2:#3B82F6"></span>
          </span>
          <p>8.6 million users worldwide — everyone is happy with our service.</p>
        </div>
      </aside>
    </div>

    <div class="hero__socials" aria-label="Social links">
      <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9V15h-2.4V12h2.4V9.8a3.4 3.4 0 0 1 3.7-3.8c1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.7-1.6 1.5V12h2.7l-.4 3h-2.3v6.9A10 10 0 0 0 22 12z"/></svg></a>
      <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 3.25.15 4.77 1.7 4.92 4.92.06 1.25.07 1.62.07 4.81s0 3.56-.07 4.81c-.15 3.21-1.66 4.77-4.92 4.92-1.25.06-1.62.07-4.85.07s-3.6 0-4.85-.07c-3.26-.15-4.77-1.71-4.92-4.92C2.17 15.56 2.16 15.19 2.16 12s0-3.56.07-4.81C2.38 3.97 3.89 2.42 7.15 2.27 8.4 2.21 8.77 2.2 12 2.2zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.95 4.95 0 0 1 12 7.06zm0 8.16A3.22 3.22 0 1 0 8.78 12 3.22 3.22 0 0 0 12 15.22zm5.13-8.36a1.16 1.16 0 1 1-1.16-1.16 1.16 1.16 0 0 1 1.16 1.16z"/></svg></a>
      <a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M22 5.8a8.5 8.5 0 0 1-2.36.65 4.07 4.07 0 0 0 1.81-2.27 8.2 8.2 0 0 1-2.6 1 4.1 4.1 0 0 0-7 3.74 11.65 11.65 0 0 1-8.45-4.3 4.1 4.1 0 0 0 1.27 5.49A4.07 4.07 0 0 1 2.8 9.6v.05a4.1 4.1 0 0 0 3.3 4 4.1 4.1 0 0 1-1.86.07 4.1 4.1 0 0 0 3.83 2.85A8.23 8.23 0 0 1 2 18.28a11.6 11.6 0 0 0 6.29 1.85c7.55 0 11.68-6.25 11.68-11.68v-.53A8.31 8.31 0 0 0 22 5.8z"/></svg></a>
      <a href="#" aria-label="Email"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4l-8 5-8-5V6l8 5 8-5z"/></svg></a>
    </div>
