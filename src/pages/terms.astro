    <div class="legal__more">
      <p><strong>Legal question?</strong> Email <a href="mailto:legal@luvmood.com">legal@luvmood.com</a>. For everyday support, <a href="mailto:hello@luvmood.com">hello@luvmood.com</a>.</p>
      <a href="/privacy/" class="textlink">Privacy Policy<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></a>
    </div>
  </main>

  <Footer />

  <script>
    const article = document.querySelector('.legal__inner');
    const tocList = document.getElementById('legalTocList');
    if (article && tocList) {
      const slugify = (s) => s.toLowerCase().trim()
        .replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-');
      const headings = Array.from(article.querySelectorAll('h2'));
      const links = headings.map((h) => {
        const id = h.id || slugify(h.textContent || '');
        h.id = id;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + id;
        a.textContent = h.textContent || '';
        li.appendChild(a);
        tocList.appendChild(li);
        return { id, a };
      });
      if ('IntersectionObserver' in window) {
        const setActive = (id) => links.forEach((l) => l.a.classList.toggle('is-active', l.id === id));
        const io = new IntersectionObserver(
          (entries) => {
            const visible = entries.filter((e) => e.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible.length) setActive(visible[0].target.id);
          },
          { rootMargin: '-110px 0px -65% 0px' },
        );
        headings.forEach((h) => io.observe(h));
        if (headings.length) setActive(headings[0].id);
      }
    }
  </script>
</Layout>
