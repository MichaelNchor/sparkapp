---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="brand" aria-label="Spark home">
        <svg class="brand__mark" viewBox="0 0 40 40" aria-hidden="true">
          <circle cx="20" cy="20" r="18.5" fill="none" stroke="#fd297b" stroke-width="1.6" />
          <path
            d="M20 28.5 L10.8 18.6 C8.2 16 9.8 10.8 14 10.8 C16.1 10.8 18.1 11.9 20 14 C21.9 11.9 23.9 10.8 26 10.8 C30.2 10.8 31.8 16 29.2 18.6 Z"
            fill="#fd297b"
          />
        </svg>
        <span class="brand__name">Spark</span>
      </a>
      <p class="footer__tag">Verified-only dating, built for people who actually want to meet someone.</p>
      <div class="footer__socials" aria-label="Spark on social">
        <a href="https://instagram.com" aria-label="Instagram"><svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 3.25.15 4.77 1.7 4.92 4.92.06 1.25.07 1.62.07 4.81s0 3.56-.07 4.81c-.15 3.21-1.66 4.77-4.92 4.92-1.25.06-1.62.07-4.85.07s-3.6 0-4.85-.07c-3.26-.15-4.77-1.71-4.92-4.92C2.17 15.56 2.16 15.19 2.16 12s0-3.56.07-4.81C2.38 3.97 3.89 2.42 7.15 2.27 8.4 2.21 8.77 2.2 12 2.2zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.95 4.95 0 0 1 12 7.06zm0 8.16A3.22 3.22 0 1 0 8.78 12 3.22 3.22 0 0 0 12 15.22zm5.13-8.36a1.16 1.16 0 1 1-1.16-1.16 1.16 1.16 0 0 1 1.16 1.16z"/></svg></a>
        <a href="https://twitter.com" aria-label="X / Twitter"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href="https://tiktok.com" aria-label="TikTok"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M16.6 5.82A4.28 4.28 0 0 1 15.5 3h-3.07v12.4a2.47 2.47 0 0 1-2.47 2.47 2.47 2.47 0 1 1 .69-4.84V9.9a5.55 5.55 0 0 0-.69-.04 5.55 5.55 0 1 0 5.55 5.55V8.86a7.32 7.32 0 0 0 4.27 1.37V7.16a4.28 4.28 0 0 1-3.18-1.34z"/></svg></a>
        <a href="mailto:hello@sparkapp.dev" aria-label="Email"><svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4l-8 5-8-5V6l8 5 8-5z"/></svg></a>
      </div>
    </div>

    <div class="footer__col">
      <h4>Product</h4>
      <ul>
        <li><a href="/#how">How it works</a></li>
        <li><a href="/#features">Features</a></li>
        <li><a href="/#verified">Verified profiles</a></li>
        <li><a href="/#get">Get the app</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Company</h4>
      <ul>
        <li><a href="/safety/">Safety</a></li>
        <li><a href="/community-guidelines/">Community guidelines</a></li>
        <li><a href="/support/">Support</a></li>
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
        <li><a href="/dmca/">DMCA</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <span>© {year} Spark. All rights reserved.</span>
    <span>Made with <span class="heart">♥</span> for real connections.</span>
  </div>
</footer>
