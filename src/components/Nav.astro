---
/**
 * Top nav. Links use anchor scrolls when on the home page; on /privacy
 * and /terms the same anchors deep-link back to the relevant section
 * via Astro's built-in href resolution.
 */
const homePrefix = Astro.url.pathname === '/' ? '' : '/';
---

<nav class="nav">
  <a href={`${homePrefix}#home`} class="nav__logo" aria-label="Spark home">
    <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
      <defs>
        <linearGradient id="logoGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#fd297b" />
          <stop offset="100%" stop-color="#ff5864" />
        </linearGradient>
      </defs>
      <circle cx="20" cy="20" r="19" fill="none" stroke="url(#logoGrad)" stroke-width="1.5" />
      <path
        d="M20 28 L11 18.5 C8.5 16 10 11 14 11 C16 11 18 12 20 14 C22 12 24 11 26 11 C30 11 31.5 16 29 18.5 Z"
        fill="url(#logoGrad)"
      />
    </svg>
  </a>

  <ul class="nav__links" role="navigation">
    <li><a href={`${homePrefix}#home`}>Home</a></li>
    <li><a href={`${homePrefix}#features`}>Features</a></li>
    <li><a href={`${homePrefix}#smartmatch`}>Smart&nbsp;Match</a></li>
    <li><a href={`${homePrefix}#download`}>Download</a></li>
  </ul>

  <a href={`${homePrefix}#download`} class="btn btn--ghost nav__cta">
    <span>Get App</span>
    <span class="nav__cta-icons" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"
        ><path
          d="M17.5 12.6c0-3.1 2.5-4.6 2.7-4.7-1.5-2.2-3.8-2.5-4.6-2.5-2-.2-3.8 1.2-4.8 1.2-1 0-2.5-1.1-4.2-1.1-2.2 0-4.2 1.3-5.3 3.2-2.3 4-.6 9.9 1.6 13.2 1.1 1.6 2.4 3.4 4.1 3.3 1.7-.1 2.3-1.1 4.3-1.1 2 0 2.6 1.1 4.4 1 1.8 0 2.9-1.6 4-3.2.5-.8.7-1.2 1.1-2.1-3-.9-3.3-4.7-3.3-5.2zM14.4 4c.9-1.1 1.5-2.6 1.4-4.1-1.3.1-2.9.9-3.8 2-.8.9-1.5 2.5-1.3 3.9 1.4.1 2.9-.7 3.7-1.8z"
        /></svg
      >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"
        ><path d="M3 2.5L13.5 12 3 21.5V2.5z" /></svg
      >
    </span>
  </a>
</nav>
