---
/**
 * Top nav. Anchor links resolve to the home page when on a subpage
 * (e.g. /safety links back to /#how). Sticky, transparent over the
 * hero, then fades in a frosted background once you scroll — wired
 * by the small inline script below so every page behaves the same.
 */
const home = Astro.url.pathname === '/' ? '' : '/';
---

<div class="nav-wrap" id="navWrap">
  <nav class="nav" aria-label="Primary">
    <a href={`${home}#top`} class="brand" aria-label="Luvmood home">
      <img class="brand__mark" src="/luvmood-heart.png?v=2" alt="" width="32" height="32" loading="eager" />
      <span class="brand__name">Luvmood</span>
    </a>

    <ul class="nav__links">
      <li><a href={`${home}#how`}>How it works</a></li>
      <li><a href={`${home}#features`}>Features</a></li>
      <li><a href={`${home}#verified`}>Verified</a></li>
      <li><a href="/safety/">Safety</a></li>
    </ul>

    <a href={`${home}#get`} class="btn btn--primary nav__cta">Get the app</a>
  </nav>
</div>

<script>
  const wrap = document.getElementById('navWrap');
  if (wrap) {
    const onScroll = () => wrap.classList.toggle('is-stuck', window.scrollY > 12);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
