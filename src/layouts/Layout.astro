---
/**
 * Shared HTML scaffolding. Every page wraps its content in <Layout>
 * which gives them the same <head>, font preloads, theme color, and
 * global stylesheet. Per-page customisation is via props (title,
 * description, ogImage); sensible defaults so most pages can pass
 * just a title.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Spark — Verified-only dating',
  description = 'Spark is a dating app where every profile is checked by a real human. Meet verified people near you, and make the first move that actually gets read.',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff9fb" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Spark" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!--
      Type system: Bricolage Grotesque carries the display voice (warm,
      a little characterful, grown-up); Hanken Grotesk is the clean
      workhorse for body + UI. Both are warm grotesques so they share
      a family feel without being the Inter/Poppins reflex.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500..800&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
